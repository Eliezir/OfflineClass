# Perfil de execução: development | production | test
NODE_ENV=development

# Porta HTTP do servidor (mantida em 8080 para o Electron/docker-compose)
PORT=8080

# Conexão SQLite (Prisma). O caminho é relativo à pasta prisma/.
DATABASE_URL="file:../database/offlineclass.db"

# Chave base64 de 32 bytes usada para criptografar a apiKey do provedor.
API_KEY_ENCRYPTION_KEY_BASE64=
