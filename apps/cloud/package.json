{
  "name": "@apresenta-ai/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.0",
  "description": "Backend da Apresenta.AI — API HTTP em TypeScript (Hono + Prisma)",
  "main": "src/main.ts",
  "scripts": {
    "dev": "prisma generate && prisma migrate deploy && prisma db seed && tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "build": "prisma generate && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dc:check": "depcruise src --config .dependency-cruiser.cjs",
    "prisma:generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "db:setup": "prisma generate && prisma migrate deploy && prisma db seed",
    "prisma:seed": "prisma db seed",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.2",
    "@prisma/client": "^6.2.1",
    "dotenv": "^16.4.7",
    "hono": "^4.6.16",
    "tsx": "^4.19.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.8",
    "dependency-cruiser": "^16.8.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "prisma": "^6.2.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1",
    "vitest": "^2.1.9"
  }
}
