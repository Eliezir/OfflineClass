# OfflineClass — backend (LAN server) configuration.
#
# Copy to `.env` for local overrides (this file is committed; `.env` is gitignored).
# Every value is optional — the defaults below are the offline-first happy path,
# so the app runs with no `.env` at all. Real environment variables (e.g. set on
# the command line) always take precedence over `.env`.

# Preferred TCP port for the LAN server. find-free-port scans upward from here,
# so if the port is busy it just bumps to the next free one (handy across
# worktrees / other running projects).
OFFLINECLASS_PORT=8000

# Interface the server binds. 0.0.0.0 exposes it to the classroom Wi-Fi so
# student devices can join; use 127.0.0.1 to keep it local-only.
OFFLINECLASS_HOST=0.0.0.0

# Socket.IO CORS origin. '*' suits the LAN (students load the SPA from the same
# origin). Set a specific origin only if the server is exposed beyond the LAN.
OFFLINECLASS_CORS_ORIGIN=*

# TLS for the LAN server: on = HTTPS (self-signed), off = plain HTTP.
# Recommended for classrooms: off — a self-signed cert can't be trusted on
# student machines without installing a CA, so HTTPS shows a "not secure"
# warning. Plain HTTP on the closed LAN removes that friction, so students
# reach http://offlineclass.local:<port> with no warning. Default is `on` to
# preserve prior behavior. See docs/realtime-groups-discovery-rnd.md.
OFFLINECLASS_TLS=on
