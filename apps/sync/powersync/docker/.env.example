# OfflineClass PowerSync Docker stack — environment variables
# Copy this file to .env and fill in real values before starting the stack.
# .env is gitignored (never commit secrets).

# ─── Source Postgres (offlineclass data) ───────────────────────────────────
PS_PG_DB_USER=offlineclass
PS_PG_DB_PASSWORD=change_me_db_password
PS_PG_DB_NAME=offlineclass
PS_PG_DB_PORT=5432

# ─── Storage Postgres (PowerSync bucket storage) ───────────────────────────
PS_PG_STORAGE_USER=ps_storage
PS_PG_STORAGE_PASSWORD=change_me_storage_password
PS_PG_STORAGE_DB=ps_storage
PS_PG_STORAGE_PORT=5433

# ─── Connection URIs (used by service.yaml) ────────────────────────────────
# These reference the container hostnames (pg-db / pg-storage) — correct for
# use inside docker-compose. Override for external Postgres.
PS_DATA_SOURCE_URI=postgresql://offlineclass:change_me_db_password@pg-db:5432/offlineclass
PS_STORAGE_URI=postgresql://ps_storage:change_me_storage_password@pg-storage:5432/ps_storage

# ─── PowerSync JWT shared secret (HS256) ───────────────────────────────────
# Must be at least 32 characters. Same value used by the connector to sign JWTs
# and by the PowerSync Service (client_auth.supabase_jwt_secret) to verify them.
PS_JWT_SECRET=change_me_to_a_random_string_at_least_32_chars

# ─── Connector ─────────────────────────────────────────────────────────────
CONNECTOR_PORT=3001
# URL of the PowerSync Service as seen by the desktop client (outside docker)
PS_SERVICE_URL=http://localhost:8080

# ─── PowerSync Service port ────────────────────────────────────────────────
POWERSYNC_PORT=8080
