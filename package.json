{
  "name": "offlineclass",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "dev": "pnpm --filter ./apps/desktop dev",
    "dev:web": "pnpm --filter ./apps/desktop dev:web",
    "dev:landing": "pnpm --filter ./apps/landing dev",
    "build": "pnpm --filter ./apps/desktop build",
    "build:landing": "pnpm --filter ./apps/landing build",
    "db:studio": "pnpm --filter ./apps/desktop db:studio",
    "lint": "pnpm --filter ./apps/desktop lint",
    "format": "pnpm --filter ./apps/desktop format",
    "typecheck": "pnpm --filter ./apps/desktop typecheck",
    "i18n:extract": "pnpm --filter ./apps/desktop i18n:extract",
    "i18n:compile": "pnpm --filter ./apps/desktop i18n:compile"
  },
  "dependencies": {
    "pnpm": "^11.8.0"
  }
}
